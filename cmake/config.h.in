#pragma once

// CLI project information (prefixed to avoid collision with lib's config.h)
#define FUS_CLI_PROJECT_NAME "@PROJECT_NAME@"
#define FUS_CLI_PROJECT_VERSION "@PROJECT_VERSION@"
#define FUS_CLI_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define FUS_CLI_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define FUS_CLI_VERSION_PATCH @PROJECT_VERSION_PATCH@

// Update version type configuration
#define UPDATE_VERSION_TYPE_STRING @UPDATE_VERSION_TYPE_STRING@
#define UPDATE_VERSION_TYPE_UINT64 @UPDATE_VERSION_TYPE_UINT64@

// Conditional compilation
#if UPDATE_VERSION_TYPE_STRING
    #define UPDATE_VERSION_TYPE std::string
    #define UPDATE_VERSION_DEFAULT ""
#elif UPDATE_VERSION_TYPE_UINT64
    #define UPDATE_VERSION_TYPE uint64_t
    #define UPDATE_VERSION_DEFAULT 0ULL
#else
    #error "No valid update version type configured"
#endif

// Build type
#ifdef NDEBUG
    #define BUILD_TYPE "Release"
#else
    #define BUILD_TYPE "Debug"
#endif
